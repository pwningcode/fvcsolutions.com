---
import BaseLayout from '../layouts/BaseLayout.astro';
import RichTitle from '../components/RichTitle.astro';
import site from '../content/site.json';
import schedule from '../content/schedule.json';

// Convert simple **bold** markdown into HTML
const mdBold = (s: string): string =>
  s.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Schedule a call', item: `${site.url}/schedule` },
  ],
};

const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  url: `${site.url}/schedule`,
  name: 'Schedule a call',
  description: 'Tell us about your project, then book a 30-minute call.',
};
---

<BaseLayout
  title="Schedule a call"
  description="Tell us about your project — a few quick questions, then book a 30-minute call. We don't ask for email or phone in the form."
  pathname="/schedule"
  jsonLd={[breadcrumbLd, contactLd]}
  noindex={false}
>
  <header class="page-head">
    <div class="container">
      <div class="breadcrumb fade-up">{schedule.head.breadcrumb}</div>
      <h1 class="fade-up delay-1">
        <RichTitle segments={schedule.head.title} />
      </h1>
      <p class="lede fade-up delay-2">{schedule.head.lede}</p>
    </div>
  </header>

  <div class="container">
    <aside class="trust-banner fade-up delay-3" aria-labelledby="trust-heading">
      <div class="trust-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
          <path d="M12 2L4 6v6c0 5 3.5 9.5 8 10 4.5-.5 8-5 8-10V6l-8-4z" />
          <path d="M9 12l2 2 4-4" />
        </svg>
      </div>
      <div>
        <h2 id="trust-heading">{schedule.trustBanner.heading}</h2>
        <p set:html={mdBold(schedule.trustBanner.body)}></p>
        <p class="nuance">{schedule.trustBanner.nuance}</p>
      </div>
    </aside>
  </div>

  <section class="how">
    <div class="container">
      <div class="how-label">{schedule.how.label}</div>
      <div class="how-steps">
        {schedule.how.steps.map((step) => (
          <div class="how-step reveal">
            <div class="how-step-num">{step.num}</div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="form-section">
    <div class="container">
      <div class="form-section-label">{schedule.form.label}</div>
      <h2 class="form-title">{schedule.form.title}</h2>

      <form id="qualForm" novalidate>
        {schedule.form.questions.map((q) => (
          <div class="field-group">
            <div class="field-num">{q.num}</div>

            {q.type === 'radio' && (
              <>
                <span class="field-label">{q.label}</span>
                {q.help && <p class="field-help">{q.help}</p>}
                <div class:list={['radio-grid', { compact: q.compact }]} role="radiogroup" aria-label={q.label}>
                  {q.options.map((opt, i) => (
                    <label class="radio-card">
                      <input
                        type="radio"
                        name={q.id}
                        value={opt.value}
                        required={q.required && i === 0 ? true : undefined}
                      />
                      <div class="card-inner">
                        <div class="card-title">{opt.title}</div>
                        <div class="card-sub">{opt.sub}</div>
                      </div>
                    </label>
                  ))}
                </div>
              </>
            )}

            {q.type === 'textarea' && (
              <>
                <label class="field-label" for={q.id}>{q.label}</label>
                {q.help && <p class="field-help">{q.help}</p>}
                <textarea id={q.id} name={q.id} required={q.required} placeholder={q.placeholder}></textarea>
              </>
            )}

            {q.type === 'text' && (
              <>
                <label class="field-label" for={q.id}>
                  {q.label}
                  {q.optional && <span class="optional">Optional</span>}
                </label>
                {q.help && <p class="field-help">{q.help}</p>}
                <input type="text" id={q.id} name={q.id} placeholder={q.placeholder} required={q.required} />
              </>
            )}

            {q.type === 'two-col' && (
              <>
                <span class="field-label">
                  {q.label}
                  {q.optional && <span class="optional">Optional</span>}
                </span>
                {q.help && <p class="field-help">{q.help}</p>}
                <div class="two-col">
                  {q.fields.map((f) => (
                    <div>
                      <label for={f.id}>{f.label}</label>
                      <input type="text" id={f.id} name={f.id} placeholder={f.placeholder} />
                    </div>
                  ))}
                </div>
              </>
            )}
          </div>
        ))}

        <div class="submit-bar">
          <button type="submit" class="btn btn-primary btn-arrow" id="submitBtn">{schedule.form.submitLabel}</button>
          <p class="submit-note" set:html={mdBold(schedule.form.submitNote)}></p>
          <noscript>
            <p class="js-note">
              JavaScript is required to forward your answers to the booking page. Please enable it, or
              <a href={site.calendly.url}>book a time directly</a>.
            </p>
          </noscript>
        </div>
      </form>
    </div>
  </section>
</BaseLayout>

<script is:inline define:vars={{ calendly: site.calendly }}>
  (function () {
    const form = document.getElementById('qualForm');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      const btn = document.getElementById('submitBtn');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Continuing…';
      }

      const data = new FormData(form);
      const params = new URLSearchParams();
      const map = calendly.questionMap;

      for (const [field, key] of Object.entries(map)) {
        const v = data.get(field);
        if (typeof v === 'string' && v.trim()) {
          params.append(key, v.trim());
        }
      }

      const sep = calendly.url.includes('?') ? '&' : '?';
      window.location.href = calendly.url + sep + params.toString();
    });
  })();
</script>

<style>
  .page-head { padding: 80px 0 48px; }
  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink-faint);
    margin-bottom: 32px;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-family: var(--mono);
  }
  .breadcrumb::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--accent);
  }
  .page-head h1 {
    font-family: var(--serif);
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 800px;
    margin-bottom: 24px;
    font-weight: 400;
  }
  .page-head h1 :global(em) { font-style: italic; color: var(--accent-warm); }
  .page-head .lede {
    font-size: 18px;
    color: var(--ink-dim);
    max-width: 620px;
    line-height: 1.6;
  }

  /* TRUST BANNER */
  .trust-banner {
    margin: 16px 0 64px;
    border: 1px solid var(--accent-deep);
    background: linear-gradient(180deg, rgba(38, 156, 72, 0.06), rgba(38, 156, 72, 0.02));
    padding: 28px 32px;
    border-radius: 2px;
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: start;
  }
  .trust-icon {
    width: 44px;
    height: 44px;
    border: 1.5px solid var(--accent);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--accent);
    flex-shrink: 0;
  }
  .trust-icon svg { width: 20px; height: 20px; }
  .trust-banner h2 {
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    margin-bottom: 12px;
    font-weight: 500;
  }
  .trust-banner p {
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    max-width: 720px;
  }
  .trust-banner p :global(strong) { color: var(--ink); font-weight: 600; }
  .trust-banner .nuance {
    color: var(--ink-dim);
    font-size: 13px;
    margin-top: 10px;
    line-height: 1.6;
  }

  /* HOW IT WORKS */
  .how {
    border-top: 1px solid var(--line);
    padding: 56px 0 24px;
    margin-bottom: 48px;
  }
  .how-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 32px;
  }
  .how-steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .how-step {
    border-top: 1px solid var(--line-bright);
    padding-top: 20px;
  }
  .how-step-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.15em;
    margin-bottom: 14px;
  }
  .how-step h3 {
    font-family: var(--serif);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .how-step p {
    color: var(--ink-dim);
    font-size: 14px;
    line-height: 1.6;
  }

  /* FORM */
  .form-section { padding: 0 0 100px; }
  .form-section-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .form-title {
    font-family: var(--serif);
    font-size: clamp(32px, 4vw, 44px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: 48px;
    font-weight: 400;
  }
  form { max-width: 760px; }
  .field-group {
    margin-bottom: 56px;
    padding-bottom: 56px;
    border-bottom: 1px solid var(--line);
  }
  .field-group:last-of-type { border-bottom: none; }
  .field-num {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.15em;
    margin-bottom: 12px;
  }
  .field-label {
    font-family: var(--serif);
    font-size: 26px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    margin-bottom: 8px;
    color: var(--ink);
    display: block;
  }
  .field-help {
    color: var(--ink-dim);
    font-size: 14px;
    margin-bottom: 24px;
    line-height: 1.55;
  }
  .optional {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-faint);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-left: 8px;
    padding: 2px 8px;
    border: 1px solid var(--line-bright);
    border-radius: 2px;
    vertical-align: middle;
  }

  /* RADIO CARDS */
  .radio-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .radio-grid.compact { grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
  .radio-card {
    position: relative;
    cursor: pointer;
    display: block;
  }
  .radio-card input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  .card-inner {
    border: 1px solid var(--line-bright);
    background: var(--bg-2);
    padding: 18px 20px;
    border-radius: 2px;
    transition: all 0.15s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 4px;
    cursor: pointer;
  }
  .radio-card:hover .card-inner {
    border-color: var(--ink-faint);
    background: var(--bg);
  }
  .radio-card input:checked + .card-inner {
    border-color: var(--accent);
    background: rgba(38, 156, 72, 0.06);
    box-shadow: inset 0 0 0 1px var(--accent);
  }
  .radio-card input:focus-visible + .card-inner {
    outline: 2px solid var(--accent-warm);
    outline-offset: 2px;
  }
  .card-title {
    color: var(--ink);
    font-size: 15px;
    font-weight: 500;
  }
  .card-sub {
    color: var(--ink-dim);
    font-size: 12.5px;
    line-height: 1.5;
  }
  .radio-card input:checked + .card-inner .card-title { color: var(--accent-warm); }

  /* TEXTAREA & INPUT */
  textarea, input[type="text"] {
    width: 100%;
    background: var(--bg-2);
    border: 1px solid var(--line-bright);
    color: var(--ink);
    padding: 16px 18px;
    font-family: inherit;
    font-size: 15px;
    line-height: 1.6;
    border-radius: 2px;
    transition: border-color 0.15s, background 0.15s;
    resize: vertical;
  }
  textarea { min-height: 130px; }
  textarea:focus, input[type="text"]:focus {
    outline: none;
    border-color: var(--accent);
    background: var(--bg);
  }
  textarea::placeholder, input::placeholder {
    color: var(--ink-faint);
    font-style: italic;
  }

  .two-col {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .two-col label {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-faint);
    margin-bottom: 8px;
  }

  /* SUBMIT */
  .submit-bar {
    margin-top: 16px;
    padding-top: 32px;
    border-top: 1px solid var(--line-bright);
    display: flex;
    flex-direction: column;
    gap: 18px;
    align-items: flex-start;
  }
  .submit-bar .btn { padding: 16px 32px; font-size: 15px; }
  .submit-note {
    color: var(--ink-faint);
    font-size: 13px;
    line-height: 1.6;
    max-width: 580px;
  }
  .submit-note :global(strong) { color: var(--ink-dim); font-weight: 500; }
  .js-note {
    font-size: 13px;
    color: var(--ink-faint);
  }
  .js-note a { color: var(--accent); text-decoration: underline; }

  @media (max-width: 900px) {
    .how-steps { grid-template-columns: 1fr; gap: 20px; }
    .radio-grid { grid-template-columns: 1fr; }
    .two-col { grid-template-columns: 1fr; }
    .trust-banner { grid-template-columns: 1fr; gap: 16px; padding: 24px; }
    .page-head { padding: 48px 0 32px; }
    .field-group { margin-bottom: 40px; padding-bottom: 40px; }
  }
</style>
